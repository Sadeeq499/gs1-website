<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>

        <!-- ═══════════════════════════════════════════════════════════════
             RULE 1: Specific API Endpoint — Foreign GTIN Product Details
             Matches exact path: /api/foreignGtin/getGtinProductDetails
             Forwards to website.gs1.org.sa with original query string
             Processed before the generic API rule to avoid conflict
        ═══════════════════════════════════════════════════════════════ -->
        <rule name="BackendAPI_Specific" stopProcessing="true">
          <match url="^api/foreignGtin/getGtinProductDetails$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTP_HOST}" pattern="^gs1\.org\.sa$" />
          </conditions>
          <action type="Rewrite" url="https://website.gs1.org.sa/api/foreignGtin/getGtinProductDetails?{QUERY_STRING}" appendQueryString="false" />
        </rule>

        <!-- ═══════════════════════════════════════════════════════════════
             RULE 2: Generic API Routes
             Matches any path starting with: /api/
             Forwards all API requests to website.gs1.org.sa backend
             Preserves the full path and query string
             Example: /api/products?id=5 → website.gs1.org.sa/api/products?id=5
        ═══════════════════════════════════════════════════════════════ -->
        <rule name="BackendAPI_All" stopProcessing="true">
          <match url="^api/(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTP_HOST}" pattern="^gs1\.org\.sa$" />
          </conditions>
          <action type="Rewrite" url="https://website.gs1.org.sa/api/{R:1}?{QUERY_STRING}" appendQueryString="false" />
        </rule>

        <!-- ═══════════════════════════════════════════════════════════════
             RULE 3: Uploaded Files
             Matches any path starting with: /uploads/
             Forwards file requests to website.gs1.org.sa uploads folder
             Example: /uploads/photo.jpg → website.gs1.org.sa/uploads/photo.jpg
        ═══════════════════════════════════════════════════════════════ -->
        <rule name="Uploads" stopProcessing="true">
          <match url="^uploads/(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTP_HOST}" pattern="^gs1\.org\.sa$" />
          </conditions>
          <action type="Rewrite" url="https://website.gs1.org.sa/uploads/{R:1}" appendQueryString="false" />
        </rule>

        <!-- ═══════════════════════════════════════════════════════════════
             RULE 4: Static Assets (Images, CSS, JS, Fonts, etc.)
             Matches any path starting with: /assets/
             Forwards static file requests to website.gs1.org.sa assets folder
             Example: /assets/gs1logowhite-BBYd3JZl.png → website.gs1.org.sa/assets/gs1logowhite-BBYd3JZl.png
        ═══════════════════════════════════════════════════════════════ -->
        <rule name="Assets" stopProcessing="true">
          <match url="^assets/(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTP_HOST}" pattern="^gs1\.org\.sa$" />
          </conditions>
          <action type="Rewrite" url="https://website.gs1.org.sa/assets/{R:1}" appendQueryString="false" />
        </rule>

         <!-- ═══════════════════════════════════════════════════════════════
             RULE 5: GEPIR Page Redirect
             Matches exact path: /gepir
             Redirects to website.gs1.org.sa/gepir with original query string
             Example: /gepir?gtin=6281035000034 → website.gs1.org.sa/gepir?gtin=6281035000034
        ═══════════════════════════════════════════════════════════════ -->
        <rule name="Gepir_Redirect" stopProcessing="true">
          <match url="^gepir$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTP_HOST}" pattern="^gs1\.org\.sa$" />
          </conditions>
          <action type="Redirect" url="https://website.gs1.org.sa/gepir?{QUERY_STRING}" redirectType="Permanent" appendQueryString="false" />
        </rule>

        <!-- ═══════════════════════════════════════════════════════════════
             RULE 6: Catch-All Reverse Proxy (Frontend App)
             Matches everything that did not match the rules above
             Forwards all remaining traffic to the local Node.js app
             running on port 1910 (Vite / Express server)
             This rule must always stay LAST
        ═══════════════════════════════════════════════════════════════ -->
        <rule name="ReverseProxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:1910/{R:1}" />
        </rule>

      </rules>
    </rewrite>
  </system.webServer>
</configuration>
